<mujoco model="ur5e_scene">

  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.53 0.71 0.87" rgb2="0.22 0.33 0.44"
             width="512" height="512"/>
    <texture name="groundplane" type="2d" builtin="checker"
             rgb1="0.65 0.65 0.65" rgb2="0.55 0.55 0.55"
             width="512" height="512" mark="edge" markrgb="0.8 0.8 0.8"/>
    <material name="groundplane" texture="groundplane"
              texrepeat="4 4" texuniform="true" reflectance="0.1"/>
    <material name="table_wood"  rgba="0.55 0.40 0.25 1"/>
    <material name="block_red"   rgba="0.85 0.20 0.20 1"/>
    <material name="block_blue"  rgba="0.20 0.40 0.85 1"/>
    <material name="palette_green"  rgba="0.20 0.75 0.30 0.5"/>
    <material name="palette_yellow" rgba="0.85 0.75 0.10 0.5"/>
  </asset>

  <worldbody>

    <!-- Lighting -->
    <light name="main_light" pos="0 0 2.5" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" castshadow="true"/>
    <light name="fill_light" pos="1 1 2" dir="-1 -1 -1"
           diffuse="0.3 0.3 0.3" specular="0 0 0" castshadow="false"/>

    <!-- Ground plane -->
    <geom name="ground" type="plane" size="3 3 0.1"
          material="groundplane" friction="0.8 0.005 0.0001"/>

    <!-- Table: 80cm × 100cm × 4cm, top surface at z=0.04 -->
    <body name="table" pos="0 0 0.02">
      <geom name="table_top" type="box" size="0.40 0.50 0.02"
            material="table_wood" friction="0.8 0.005 0.0001"/>
    </body>

    <!-- Graspable blocks (freejoint = physically simulated) -->
    <!-- Block A (red): sits on table surface, in front-right of arm -->
    <body name="block_a" pos="0.30 0.15 0.065">
      <freejoint name="block_a_joint"/>
      <geom name="block_a_geom" type="box" size="0.025 0.025 0.025"
            material="block_red" mass="0.05" friction="0.9 0.005 0.0001"/>
    </body>

    <!-- Block B (blue): sits on table surface, in front-left of arm -->
    <body name="block_b" pos="0.30 -0.15 0.065">
      <freejoint name="block_b_joint"/>
      <geom name="block_b_geom" type="box" size="0.025 0.025 0.025"
            material="block_blue" mass="0.05" friction="0.9 0.005 0.0001"/>
    </body>

    <!-- Target palettes (contype=0 conaffinity=0 = visual only, no collision) -->
    <body name="palette_a" pos="-0.10 0.30 0.042">
      <geom name="palette_a_geom" type="box" size="0.07 0.07 0.002"
            material="palette_green" contype="0" conaffinity="0"/>
    </body>

    <body name="palette_b" pos="-0.10 -0.30 0.042">
      <geom name="palette_b_geom" type="box" size="0.07 0.07 0.002"
            material="palette_yellow" contype="0" conaffinity="0"/>
    </body>

  </worldbody>

</mujoco>