<mujoco model="ur5e_scene">

  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>

    <light name="main_light" pos="0 0 2.5" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" castshadow="true"/>
    <light name="fill_light" pos="1 1 2" dir="-1 -1 -1"
           diffuse="0.3 0.3 0.3" specular="0 0 0" castshadow="false"/>

    <!-- Ground plane -->
    <geom name="ground" type="plane" size="3 3 0.1"
          rgba="0.65 0.65 0.65 1" friction="0.8 0.005 0.0001"/>

    <!-- Table: top surface at z=0.04 -->
    <body name="table" pos="0 0 0.02">
      <geom name="table_top" type="box" size="0.40 0.50 0.02"
            rgba="0.55 0.40 0.25 1" friction="0.8 0.005 0.0001"/>
    </body>

    <!-- Block A (red) -->
    <body name="block_a" pos="0.30 0.15 0.065">
      <freejoint name="block_a_joint"/>
      <geom name="block_a_geom" type="box" size="0.025 0.025 0.025"
            rgba="0.85 0.20 0.20 1" mass="0.05" friction="0.9 0.005 0.0001"/>
    </body>

    <!-- Block B (blue) -->
    <body name="block_b" pos="0.30 -0.15 0.065">
      <freejoint name="block_b_joint"/>
      <geom name="block_b_geom" type="box" size="0.025 0.025 0.025"
            rgba="0.20 0.40 0.85 1" mass="0.05" friction="0.9 0.005 0.0001"/>
    </body>

    <!-- Palette A (green, visual only) -->
    <body name="palette_a" pos="-0.10 0.30 0.042">
      <geom name="palette_a_geom" type="box" size="0.07 0.07 0.002"
            rgba="0.20 0.75 0.30 0.5" contype="0" conaffinity="0"/>
    </body>

    <!-- Palette B (yellow, visual only) -->
    <body name="palette_b" pos="-0.10 -0.30 0.042">
      <geom name="palette_b_geom" type="box" size="0.07 0.07 0.002"
            rgba="0.85 0.75 0.10 0.5" contype="0" conaffinity="0"/>
    </body>

  </worldbody>

</mujoco>